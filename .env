APP_ENV=prod
APP_DEBUG=0
APP_SECRET=replace-with-a-long-random-app-secret

DATABASE_URL="pgsql://app:app@postgres:5432/notifications?serverVersion=13&charset=utf8"
REDIS_HOST=redis
REDIS_PORT=6379
TOKEN_TTL_SECONDS=2592000
DEFAULT_TOPIC=default
INTERNAL_API_SECRET=replace-with-a-long-random-internal-secret
INTERNAL_REGISTRATION_ENABLED=0
